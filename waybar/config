    {
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 6,
    
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": ["network#wifi", "network#eth", "pulseaudio", "battery", "custom/session"],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}",
        "onclick": "activate",
    },

    "clock": {
        "format": "ΎΑΩ {:%a %d %b  %H:%M}",
        "tooltip": false
    },

    "battery": {
        "interval": 30,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "ΎΘο {capacity}%",
        "format-plugged": "ΎΘο {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "Ύγσ muted",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "scroll-step": 5,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },

    "network#wifi": {
        "interface": "wlp4s0",
        "interval": 2,
        "format-wifi": "ΎΒλ {bandwidthUpBytes} ΎΒμ {bandwidthDownBytes}  ΎΘτ {essid}",
        "format-disconnected": "έγι Disconnected",
        "tooltip": false
    },
    "network#eth": {
        "interface": "enp3s0",
        "interval": 2,
        "format-ethernet": "ΎηΨ eth ΎΒλ {bandwidthUpBytes} ΎΒμ {bandwidthDownBytes}",
        "format-disconnected": "",
        "tooltip": false
    },

    "custom/session": {
        "format": "ΎΑΣ",
        "on-click": "wlogout -b 2",
        "tooltip": false
    }
}
